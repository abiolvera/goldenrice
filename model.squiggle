// == Helper Functions ==

@hide
interpolate(data, year) = {
  sorted = List.sortBy(data, {|d| d.year})
  years = List.map(sorted, {|d| d.year})

  if year <= List.first(years) then List.first(sorted).deaths else if year >=
    List.last(years) then List.last(sorted).deaths else {
    idx = List.findIndex(years, {|y| y > year})
    y0 = years[idx - 1]
    y1 = years[idx]
    v0 = sorted[idx - 1].deaths
    v1 = sorted[idx].deaths
    t = (year - y0) / (y1 - y0)
    v0 + t * (v1 - v0)
  }
}

@hide
interpolateCoverage(data, year) = {
  sorted = List.sortBy(data, {|d| d.year})
  years = List.map(sorted, {|d| d.year})

  if year <= List.first(years) then List.first(sorted).coverage else if year >=
    List.last(years) then List.last(sorted).coverage else {
    idx = List.findIndex(years, {|y| y > year})
    y0 = years[idx - 1]
    y1 = years[idx]
    v0 = sorted[idx - 1].coverage
    v1 = sorted[idx].coverage
    t = (year - y0) / (y1 - y0)
    v0 + t * (v1 - v0)
  }
}

@hide
logisticAdoption(
  yearsDeployed,
  ceiling,
  midpoint,
  steepness
) = if yearsDeployed <= 0 then 0 else {
  sigmoid = 1 / (1 + exp(-steepness * (yearsDeployed - midpoint)))
  ceiling * sigmoid
}

@hide
populationAttributableFraction(prevalence, relativeRisk) = {
  excess = prevalence * (relativeRisk - 1)
  excess / (1 + excess)
}

@hide
grVitaminAEfficacy(country) = {
  dailyRiceG = country.riceConsumptionKgPerCapitaYr / 365 * 1000
  childRiceG = dailyRiceG * params.childRiceFraction

  betaCaroteneUg = childRiceG * params.betaCaroteneUgPerG *
    params.storageRetention *
    params.cookingRetention

  raeDelivered = betaCaroteneUg / params.bioconversionRatio
  efficacyRaw = raeDelivered / params.childRdaUgRae
  efficacy = min(efficacyRaw, 1)

  { efficacy: efficacy, raePerDay: raeDelivered }
}

// == Core Calculation ==

@hide
calculateCountryYear(country, year) = {
  u5Deaths = interpolate(country.under5Deaths, year)

  yearsSinceBaseline = year - country.vadBaselineYear
  vadPrevRaw = country.vadBaselinePrevalence *
    (1 - country.vadAnnualDecline) ^ yearsSinceBaseline
  vadPrev = max(vadPrevRaw, 0.02)

  paf = populationAttributableFraction(vadPrev, country.relativeRiskVad)
  vadDeaths = u5Deaths * paf

  vasCov = interpolateCoverage(country.vasCoverage, year)
  effectiveVas = vasCov * params.vasEffectiveness

  deathsUnprotected = vadDeaths * (1 - effectiveVas)

  yearsDeployed = year - country.grDeploymentYear
  effectiveCeiling = country.domesticRiceFraction * params.adoptionCeiling *
    country.riceEatingVadFraction

  adoption = logisticAdoption(
    yearsDeployed,
    effectiveCeiling,
    params.adoptionMidpoint,
    params.adoptionSteepness
  )

  grEff = grVitaminAEfficacy(country)
  concaveEfficacy = grEff.efficacy ^ params.doseResponseConcavity

  livesSaved = deathsUnprotected * adoption * concaveEfficacy

  finalLives = if params.includeMaternalDeaths then livesSaved *
    (1 + params.maternalDeathFraction) else livesSaved

  {
    year: year,
    country: country.name,
    u5Deaths: u5Deaths,
    vadPrevalence: vadPrev,
    adoption: adoption,
    livesSaved: finalLives,
  }
}

@hide
calculateCountry(country) = {
  years = List.upTo(params.modelStartYear, params.modelEndYear)
  List.map(years, {|year| calculateCountryYear(country, year)})
}

// == Aggregate Results ==

@hide
allResults = List.map(countries, calculateCountry) -> List.flatten

@hide
totalLivesByYear = List.reduce(
  allResults,
  {},
  {
    |acc, r|
    currentTotal = Dict.has(acc, String.make(r.year)) ? acc[String.make(
      r.year
    )] : 0
    Dict.set(acc, String.make(r.year), currentTotal + r.livesSaved)
  }
)

@name("Total Lives Saved")
@format(",.0f")
totalLivesSaved = List.reduce(allResults, 0, {|acc, r| acc + r.livesSaved})

@hide
countryLivesList = List.map(
  countries,
  {
    |country|
    countryResults = List.filter(allResults, {|r| r.country == country.name})
    total = List.reduce(countryResults, 0, {|acc, r| acc + r.livesSaved})
    { name: country.name, livesSaved: total }
  }
)

@name("Lives Saved by Country")
livesByCountry = {
  xScale = Scale.log({ min: 100, max: 100000, title: "Lives Saved" })

  Table.make(
    countryLivesList,
    {
      columns: [
        { name: "Country", fn: {|r| r.name} },
        { name: "Median", fn: {|r| Dist.inv(r.livesSaved, 0.5)} },
        {
          name: "Distribution",
          fn: {
            |r|
            Plot.dist(
              r.livesSaved,
              {
                xScale: xScale,
                showSummary: false,
              }
            )
          },
        },
      ],
    }
  )
}

@name("DALYs Prevented")
dalysPrevented = {
  @name("Years of Life Lost Prevented") @format(",.0f")
  yll = totalLivesSaved * params.dalyYearsPerDeath

  blindChildrenPrevented = totalLivesSaved * params.dalyBlindnessPerDeath

  @name("Years Lived with Disability Prevented") @format(",.0f")
  yld = blindChildrenPrevented * params.dalyPerBlindChild

  @name("Total DALYs Prevented") @format(",.0f")
  totalDalys = yll + yld

  { yll, yld, total: totalDalys }
}

// == Cost-Effectiveness Analysis ==

@name("CEA Benchmarks")
@hide
cea = {
  // Golden Rice R&D + deployment costs
  // IRRI GR program: ~$100M (1999-2021) + Gates Foundation: ~$50M
  @name("GR R&D Cost (USD)")
  grRdCostUsd = 150000000

  // Per-country cost: introgression, trials, seed system, extension
  // HarvestPlus analogous biofortified crop deployment: $5-12M/country [EST]
  @name("GR Deployment Cost per Country (USD)")
  grDeploymentCostPerCountryUsd = 8000000

  @name("Number of Deployment Countries")
  grNDeploymentCountries = 11

  // VAS: full program cost incl. distribution, cold chain, outreach
  // HKI/UNICEF/WHO: $0.50-2.00/child/year. Central: $1.20
  @name("VAS Cost per Child per Year (USD)")
  vasCostPerChildPerYearUsd = 1.2

  // Imdad 2022 Cochrane: 24% reduction in all-cause mortality
  // ~20/1000 U5 deaths/yr in high-VAD settings × 24% = ~4.8 lives/1000/year
  @name("VAS Lives Saved per 1000 Children")
  vasLivesSavedPer1000 = 4.8

  // Rice fortification: mandatory mill-level adding synthetic vit A palmitate
  // GAIN/WFP: $0.10-0.30/person/year. Central: $0.18
  @name("Rice Fortification Cost per Person per Year (USD)")
  riceFortCostPerPersonPerYearUsd = 0.18

  // GiveWell's 2023 "bar": ~$5,000/life equivalent (AMF malaria nets)
  @name("GiveWell Bar (USD per Life)")
  givewellBarUsdPerLife = 5000

  {
    grRdCostUsd,
    grDeploymentCostPerCountryUsd,
    grNDeploymentCountries,
    vasCostPerChildPerYearUsd,
    vasLivesSavedPer1000,
    riceFortCostPerPersonPerYearUsd,
    givewellBarUsdPerLife,
  }
}

@name("Cost-Effectiveness Results")
costEffectiveness = {
  @name("Total GR Program Cost") @format("$,.0f")
  totalGrCost = cea.grRdCostUsd +
    cea.grDeploymentCostPerCountryUsd * cea.grNDeploymentCountries

  @name("GR: Cost per Life Saved") @format("$,.0f")
  costPerLifeGr = totalGrCost / totalLivesSaved

  @name("VAS: Cost per Life Saved") @format("$,.0f")
  costPerLifeVas = cea.vasCostPerChildPerYearUsd * 1000 /
    cea.vasLivesSavedPer1000

  // Rice fortification comparator (rough estimate)
  // ~250M rice-eating children in model countries × $0.18/person × 25 years
  @hide
  targetRiceChildren = 250000000
  @hide
  annualFortCost = targetRiceChildren * cea.riceFortCostPerPersonPerYearUsd
  @hide
  modelYears = params.modelEndYear - params.modelStartYear + 1
  @hide
  totalFortCost = annualFortCost * modelYears
  // Assume fortification ~2x more effective delivery (instant, no adoption lag)
  @hide
  fortLivesSavedEst = totalLivesSaved * 2

  @name("Rice Fortification: Cost per Life Saved") @format("$,.0f")
  costPerLifeFort = totalFortCost / fortLivesSavedEst

  @name("GiveWell Bar (AMF Nets)") @format("$,.0f")
  givewellBar = cea.givewellBarUsdPerLife

  {
    totalGrCost,
    costPerLifeGr,
    costPerLifeVas,
    costPerLifeFort,
    givewellBar,
  }
}

// == Tests ==

@hide
helper_tests = sTest.describe(
  "Helper Function Tests",
  [
    sTest.test(
      "interpolate returns first value for early year",
      {|| sTest.expect(interpolate(countryData.bgd.under5Deaths, 1990)).toBe(250000)}
    ),
    sTest.test(
      "interpolate returns last value for late year",
      {|| sTest.expect(interpolate(countryData.bgd.under5Deaths, 2030)).toBe(36000)}
    ),
    sTest.test(
      "logistic adoption is 0 before deployment",
      {|| sTest.expect(logisticAdoption(-1, 0.7, 8, 0.45)).toBe(0)}
    ),
    sTest.test(
      "PAF is between 0 and 1",
      {
        ||
        paf = populationAttributableFraction(0.3, 1.75)
        sTest.expect(paf).toBeGreaterThan(0)
      }
    ),
    sTest.test(
      "PAF is less than 1",
      {
        ||
        paf = populationAttributableFraction(0.3, 1.75)
        sTest.expect(paf).toBeLessThan(1)
      }
    ),
  ]
)

@hide
model_tests = sTest.describe(
  "Model Calculation Tests",
  [
    sTest.test(
      "total lives saved is positive",
      {|| sTest.expect(mean(totalLivesSaved)).toBeGreaterThan(0)}
    ),
    sTest.test(
      "total lives saved is reasonable",
      {|| sTest.expect(mean(totalLivesSaved)).toBeLessThan(10000000)}
    ),
    sTest.test(
      "DALYs total is greater than YLL",
      {
        ||
        sTest.expect(mean(dalysPrevented.total)).toBeGreaterThan(
          mean(dalysPrevented.yll)
        )
      }
    ),
  ]
)

// == Summary ==

@notebook
@startOpen
summary = [
  "## Golden Rice Counterfactual Model

This model estimates lives saved if Golden Rice (GR2E) had been approved globally in 2005 instead of facing regulatory delays.

**Theory of Change:**
Golden Rice → daily beta-carotene in staple food → reduced vitamin A deficiency (VAD) → reduced VAD-attributable under-5 mortality

**Key Results:**",
  { totalLivesSaved, dalysPrevented, costEffectiveness },
  "## Lives Saved by Country",
  livesByCountry,
  "## Countries Modeled

The model covers 11 countries representing ~85% of potential GR impact:

**South/Southeast Asia:**
- **Bangladesh**: Highest per-capita rice consumption, strong IRRI partnership
- **Philippines**: IRRI headquarters, first actual approval in 2021
- **India**: Largest absolute burden due to population size (rice-belt states only, 55% of VAD pop)
- **Indonesia**: High VAD prevalence, rice-dominant diet
- **Vietnam**: High rice consumption, rapidly declining VAD due to economic growth
- **Myanmar**: Very high rice consumption, weaker health infrastructure, VAS declined post-coup
- **Cambodia**: Highest rice consumption globally, extreme rice dependency
- **Laos**: Second-highest rice consumption, high historical VAD

**South Asia:**
- **Nepal**: High VAD in Terai lowlands, rice dominant in target zone (65% of VAD pop)

**Africa:**
- **Nigeria**: Largest African under-5 burden, but rice is secondary staple (35% of VAD pop eats rice)
- **Tanzania**: HarvestPlus target, rice limited to coastal/lake zones (28% of VAD pop)

## Model Assumptions

**Nutritional Parameters (corrected from research):**
- Beta-carotene content: " +
    String(Dist.inv(params.betaCaroteneUgPerG, 0.5), ",.1f") +
    " µg/g (Swamy et al. 2019 regulatory dataset: mean 3.57, range 1.96-7.31 µg/g milled GR2E from Philippine field trials)
- Storage retention: " +
    String(Dist.inv(params.storageRetention, 0.5) * 100, ",.0f") +
    "% (Bollinedi 2019: 84% lost at 6 months ambient; Schaub 2017: 87% lost at 10 weeks)
- Cooking retention: " +
    String(Dist.inv(params.cookingRetention, 0.5) * 100, ",.0f") +
    "% (IRRI standard: ~20% loss during boiling)
- Bioconversion ratio: " +
    String(Dist.inv(params.bioconversionRatio, 0.5), ",.0f") +
    ":1 (WHO 12:1 conservative; Tang 2009 adults 3.8:1; Tang 2012 children 2.3:1 retracted on ethical grounds)
- Combined field-to-plate delivery: ~" +
    String(
      Dist.inv(
        params.betaCaroteneUgPerG * params.storageRetention *
          params.cookingRetention,
        0.5
      ),
      ",.1f"
    ) +
    " µg/g (5th-95th: " +
    String(
      Dist.inv(
        params.betaCaroteneUgPerG * params.storageRetention *
          params.cookingRetention,
        0.05
      ),
      ",.2f"
    ) +
    "-" +
    String(
      Dist.inv(
        params.betaCaroteneUgPerG * params.storageRetention *
          params.cookingRetention,
        0.95
      ),
      ",.1f"
    ) +
    " µg/g)

**Mortality Model:**
- Relative risk: Country-specific (range 1.05-1.80), based on RCT evidence per country (Sommer 1986, West 1991, DEVTA 2013, Ghana VAST 1993)
- VAS coverage: Historical with documented structural collapses (Myanmar 2021 coup, Philippines Dengvaxia scandal, COVID-19 drops)

**Adoption Dynamics:**
- Logistic S-curve; midpoint: " +
    String(Dist.inv(params.adoptionMidpoint, 0.5), ",.0f") +
    " years; ceiling: " +
    String(Dist.inv(params.adoptionCeiling, 0.5) * 100, ",.0f") +
    "% (adjusted for domestic rice fraction and rice-eating populations)
- No GMO staple crop has ever been deployed at scale to subsistence farmers — adoption ceiling is speculative

## Key Uncertainties

1. **Beta-Carotene Content:** Swamy 2019 field data (3.57 µg/g) is ~5x lower than the 18 µg/g commonly used in advocacy models. The 14-22 µg/g figure has no identified published source and likely conflates Bangladesh total carotenoids with beta-carotene.

2. **Storage Degradation (dominant loss factor):** 68-84% lost at 6 months tropical ambient. This is the single largest reduction in the nutritional chain and was not adequately accounted for in published impact models (Stein 2006, Swamy 2019 regulatory claims).

3. **Bioconversion in Malnourished Children:** Tang 2009 (3.8:1) was measured in healthy US adults. Severely malnourished children with gut enteropathy may have much worse absorption. BCMO1 genetic polymorphism reduces conversion by ~57% in carriers (~8% of SE Asian populations).

4. **Relative Risk:** DEVTA mega-trial in India (n=1M) found near-null RR=0.96. VAS does NOT reduce malaria mortality (Ghana VAST 1993), limiting benefit in African countries where malaria dominates under-5 deaths.

5. **Adoption Ceiling:** Assumes " +
    String(Dist.inv(params.adoptionCeiling, 0.5) * 100, ",.0f") +
    "% max, but no GMO staple has ever achieved this. Philippines real-world experience: 227 hectares out of 5M total, then halted by court order (April 2024).

## Major Caveats

- GR2E has **never been commercially cultivated at scale anywhere** (as of 2025)
- Philippine biosafety permit **revoked by Court of Appeals** (April 2024); Supreme Court appeal pending
- Bangladesh application **pending since November 2017** (7+ years, no decision)
- Model uses country-specific VAD decline rates and relative risk values
- Does not include cognitive/developmental benefits, only mortality
- Does not model VAS funding crowding-out
- Dose-response concavity (median " +
    String(Dist.inv(params.doseResponseConcavity, 0.5), ",.2f") +
    ") is speculative — no empirical basis for sub-full-dose mortality relationships

**Interpreting Results**: The median estimate of **" +
    String(Dist.inv(totalLivesSaved, 0.5), ",.0f") +
    "** lives saved (90% CI: " +
    String(Dist.inv(totalLivesSaved, 0.05), ",.0f") +
    "-" +
    String(Dist.inv(totalLivesSaved, 0.95), ",.0f") +
    ") reflects corrected parameters from Swamy 2019 field data and Bollinedi 2019 storage studies. This is substantially lower than estimates in published advocacy literature (Stein 2006, Wesseler 2014) which used higher beta-carotene content and did not account for storage degradation.",
]
