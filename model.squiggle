// Golden Rice Counterfactual Model
// Estimates lives saved if Golden Rice had been approved globally in 2005

import "./sTest.squiggle" as sTest

// == Model Parameters ==

@name("Model Parameters")
params = {
  @name("Model Start Year")
  modelStartYear = 2000

  @name("Model End Year")
  modelEndYear = 2024

  @name("Beta-carotene (µg/g dry)")
  @doc(
    "GR2E field data (Swamy et al. 2019, J. Agric. Food Chem.): mean 3.57 µg/g milled rice, range 1.96-7.31 across 4 Philippine field sites. Used in regulatory dossiers for AU/NZ, Canada, USA, Philippines. Lab GR2 value of 31 µg/g is greenhouse-only, not field-realistic."
  )
  betaCaroteneUgPerG = 2 to 7

  @name("Storage Retention")
  @doc(
    "Fraction retained after tropical storage. Bollinedi et al. 2019: 84% lost at 6 months ambient (polished white rice, 16% retained). Schaub et al. 2017: 13% retained at 10 weeks. Better-case (1-month): ~60% retained. Range reflects 1-6 month storage variation."
  )
  storageRetention = 0.15 to 0.4

  @name("Cooking Retention")
  @doc(
    "Fraction retained after boiling. IRRI standard: ~20% loss during cooking. Cooking is a smaller loss factor than storage."
  )
  cookingRetention = 0.75 to 0.85

  @name("Bioconversion Ratio")
  @doc("µg beta-carotene per 1 µg RAE. WHO: 12:1, GR-specific: 3.8:1")
  bioconversionRatio = mx([8 to 14, 4 to 18], [0.8, 0.2])

  @name("Child RDA (µg RAE/day)")
  childRdaUgRae = 400

  @name("Child Rice Fraction")
  @doc(
    "Fraction of adult rice intake consumed by child. Highly uncertain - varies by age (infants ~20%, older children ~35%), feeding practices, and household food allocation norms. This affects how much beta-carotene children actually receive from Golden Rice."
  )
  childRiceFraction = 0.25 to 0.35

  @name("Adoption Midpoint (years)")
  @doc("Years to 50% adoption after deployment")
  adoptionMidpoint = 6 to 10

  @name("Adoption Steepness")
  adoptionSteepness = 0.4 to 0.5

  @name("Adoption Ceiling")
  @doc(
    "Maximum adoption fraction. Highly uncertain - depends on yield parity (unproven at scale), consumer preferences for white rice, seed system reach, and farmer risk aversion. Range: 50% (pessimistic) to 90% (optimistic). May be lower in contexts with strong white rice preferences or if yield penalties emerge."
  )
  adoptionCeiling = 0.6 to 0.8

  @name("VAS Effectiveness Multiplier")
  @doc("Adjusts for biannual gaps, cold chain issues")
  vasEffectiveness = 0.6 to 0.8

  @name("Dose-Response Concavity")
  @doc(
    "Exponent for concave dose-response. 1.0=linear, 0.5=sqrt. This parameter is highly speculative - RCT evidence is for full bolus doses, not partial daily intake. The assumption is that restoring severely depleted stores prevents more deaths per RAE unit than incremental top-up near adequacy. No direct empirical basis for the 0.55-0.75 range."
  )
  doseResponseConcavity = 0.55 to 0.75

  @name("Include Maternal Deaths")
  includeMaternalDeaths = false

  @name("Maternal Death Fraction")
  maternalDeathFraction = 0.15

  @name("DALY Years per Death")
  dalyYearsPerDeath = 28

  @name("DALY Blindness Ratio")
  @doc("Blind survivors per death")
  dalyBlindnessPerDeath = 0.8

  @name("DALY per Blind Child")
  dalyPerBlindChild = 21

  {
    modelStartYear,
    modelEndYear,
    betaCaroteneUgPerG,
    storageRetention,
    cookingRetention,
    bioconversionRatio,
    childRdaUgRae,
    childRiceFraction,
    adoptionMidpoint,
    adoptionSteepness,
    adoptionCeiling,
    vasEffectiveness,
    doseResponseConcavity,
    includeMaternalDeaths,
    maternalDeathFraction,
    dalyYearsPerDeath,
    dalyBlindnessPerDeath,
    dalyPerBlindChild,
  }
}

